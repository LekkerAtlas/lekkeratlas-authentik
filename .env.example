# Copy this file to .env and fill in real values.
# Do not commit .env.

# ---------------------------------------------------------------------
# Authentik image
# ---------------------------------------------------------------------

AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.2.4

# ---------------------------------------------------------------------
# Local development ports
# ---------------------------------------------------------------------

COMPOSE_PORT_HTTP=9000
COMPOSE_PORT_HTTPS=9443

# ---------------------------------------------------------------------
# PostgreSQL
# Generate PG_PASS with:
#   openssl rand -base64 36 | tr -d '\n'
# ---------------------------------------------------------------------

PG_USER=authentik
PG_DB=authentik
PG_PASS=change-me-generate-a-real-value

# ---------------------------------------------------------------------
# Authentik runtime config
# Generate AUTHENTIK_SECRET_KEY with:
#   openssl rand -base64 60 | tr -d '\n'
# ---------------------------------------------------------------------

AUTHENTIK_TAG=2026.5.3
AUTHENTIK_BRAND_DOMAIN=localhost
AUTHENTIK_SECRET_KEY=change-me-generate-a-real-value
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# Optional first-boot bootstrap values for local development.
# These are only useful for a fresh database.
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me-local-dev-only
AUTHENTIK_BOOTSTRAP_TOKEN=change-me-local-dev-only

# ---------------------------------------------------------------------
# Blueprint secrets
# These are used by !Env references in authentik/blueprints/*.yaml.
# ---------------------------------------------------------------------

AUTHENTIK_LEKKERATLAS_FQDN=http://localhost:3000
AUTHENTIK_LEKKERATLAS_REDIRECT_URI=http://localhost:3000
AUTHENTIK_LEKKERATLAS_WEBHOOK_FQDN=http://host.docker.internal:3000/webhooks/authentik
#AUTHENTIK_LEKKERATLAS_WEBHOOK_FQDN=$AUTHENTIK_LEKKERATLAS_FQDN/webhooks/authentik
AUTHENTIK_WEBHOOK_SYNC_LEKKERATLAS_DB_BEARER_TOKEN=change-me-token
AUTHENTIK_PROVIDER_FOR_LEKKERATLAS_CLIENT_SECRET=change-me
AUTHENTIK_RABBITMQ_CLIENT_SECRET=change-me
